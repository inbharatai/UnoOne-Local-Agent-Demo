# UnoOne Local Agent — Environment Template
#
# Copy this file to .env and fill in your local model paths.
# Never commit .env or real model binaries to version control.

# Local LLM model directory (Gemma-compatible ONNX)
LOCAL_LLM_MODEL_PATH=models/gemma-local/

# Sherpa-ONNX STT model directory
STT_MODEL_PATH=models/sherpa-asr/

# Sherpa-ONNX / Piper TTS model directory
TTS_MODEL_PATH=models/sherpa-tts/

# VAD / Wake-word model directory
VAD_MODEL_PATH=models/vad/

# Optional OCR model directory
OCR_MODEL_PATH=models/ocr-optional/

# Optional punctuation model directory
PUNCTUATION_MODEL_PATH=models/punctuation/
